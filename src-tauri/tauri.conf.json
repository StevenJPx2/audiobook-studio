{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audiobook Studio",
  "version": "0.1.0",
  "identifier": "com.audiobookstudio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Audiobook Studio",
        "width": 1080,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
