# ── Rust ──
/target/
**/*.rs.bk
*.pdb

# ── Python sidecar ──
sidecar/.venv/
**/__pycache__/
*.pyc
.python-version

# ── Generated audio / output ──
*.mp3
*.m4b
*.wav

# ── OS / editor ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Logs / temp ──
*.log
.meta.ffmeta
.concat.txt

# ── Vendored native libs (downloaded, not source; bundled into the .app) ──
vendor/

# ── PyInstaller freeze artifacts (generated by scripts/freeze-sidecar.sh) ──
sidecar/build/
sidecar/dist/
sidecar/*.spec

# ── Packaged app output ──
dist-app/
*.app
